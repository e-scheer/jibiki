---
import type { Messages } from '../i18n/messages';

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section class="section trust-section">
  <div class="container trust-grid">
    <div class="trust-copy">
      <span class="kicker">{t.trust.kicker}</span>
      <h2>{t.trust.title}</h2>
      <p class="section-copy">{t.trust.body}</p>
      <a class="button button--paper" href={t.routes.sources}>{t.trust.sourcesLink}</a>
    </div>
    <div class="trust-items">
      {t.trust.items.map((item, index) => (
        <article class={`trust-card trust-card--${index + 1}`}>
          <span aria-hidden="true">{item.icon}</span>
          <div><h3>{item.title}</h3><p>{item.body}</p></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-section {
    border-bottom: var(--line);
    background: var(--canvas);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(28rem, 1.1fr);
    align-items: center;
    gap: clamp(3rem, 7vw, 7rem);
  }

  h2 {
    max-width: 11ch;
  }

  .trust-copy .button {
    margin-top: 1rem;
  }

  .trust-items {
    display: grid;
    gap: 1rem;
  }

  .trust-card {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem;
    border: var(--line);
    border-radius: 14px;
    background: #fff;
    box-shadow: var(--shadow);
  }

  .trust-card--2 {
    margin-left: 3rem;
    background: var(--lime);
  }

  .trust-card--3 {
    margin-right: 2rem;
    background: var(--lavender);
  }

  .trust-card > span {
    display: grid;
    width: 4.5rem;
    height: 4.5rem;
    place-items: center;
    border: 2.5px solid var(--ink);
    border-radius: 12px;
    background: var(--acid);
    box-shadow: 3px 3px 0 var(--ink);
    font-family: 'Zen Kaku Gothic New', sans-serif;
    font-size: 2rem;
    font-weight: 900;
  }

  .trust-card--2 > span { background: var(--magenta); }
  .trust-card--3 > span { background: var(--klein); color: #fff; }

  .trust-card h3 {
    margin-bottom: 0.35rem;
  }

  .trust-card p {
    margin: 0;
    color: var(--ink-2);
    font-size: 0.88rem;
  }

  @media (max-width: 799px) {
    .trust-grid {
      grid-template-columns: 1fr;
    }

    .trust-card--2,
    .trust-card--3 {
      margin: 0;
    }
  }

  @media (max-width: 599px) {
    .trust-card {
      align-items: start;
    }

    .trust-card > span {
      width: 3.5rem;
      height: 3.5rem;
      font-size: 1.5rem;
    }
  }
</style>
