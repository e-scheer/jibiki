---
import type { Locale, Messages } from '../i18n/messages';
import Brand from './Brand.astro';

interface Props {
  t: Messages;
  alternatePath: string;
  alternateLocale: Locale;
  appUrl: string;
}

const { t, alternatePath, alternateLocale, appUrl } = Astro.props;
const home = t.routes.home;
const links = [
  { href: `${home}#dictionary`, label: t.header.dictionary },
  { href: `${home}#method`, label: t.header.method },
  { href: `${home}#tablet`, label: t.header.tablet },
  { href: `${home}#community`, label: t.header.community },
];
---

<header class="site-header">
  <div class="header-shell">
    <a class="brand-link" href={home} aria-label={t.common.brandLabel}>
      <Brand label={t.common.brandLabel} />
    </a>

    <nav class="desktop-nav" aria-label={t.common.navigation}>
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <div class="header-actions">
      <a class="language-link" href={alternatePath} lang={alternateLocale} hreflang={alternateLocale} aria-label={`${t.common.language}: ${alternateLocale.toUpperCase()}`}>
        {alternateLocale.toUpperCase()}
      </a>
      <a class="button button--small header-cta" href={appUrl} data-analytics-event="open_app_clicked">
        {t.common.openApp}
        <svg class="app-arrow" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13m-5-5 5 5-5 5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </a>
      <details class="mobile-menu">
        <summary aria-label={t.common.navigation}>
          <span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span>
        </summary>
        <nav aria-label={t.common.navigation}>
          {links.map((link) => <a href={link.href}>{link.label}</a>)}
          <a href={alternatePath} lang={alternateLocale} hreflang={alternateLocale}>{alternateLocale.toUpperCase()}</a>
          <a class="button" href={appUrl} data-analytics-event="open_app_clicked">{t.common.openApp}</a>
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 100;
    top: 0;
    padding: 0.7rem 1rem;
    pointer-events: none;
  }

  .header-shell {
    display: flex;
    width: min(100%, var(--content));
    min-height: 4.35rem;
    align-items: center;
    gap: 1.5rem;
    margin-inline: auto;
    padding: 0.45rem 0.55rem 0.45rem 0.8rem;
    border: var(--line);
    border-radius: 16px;
    background: rgb(255 255 255 / 94%);
    box-shadow: var(--shadow);
    backdrop-filter: blur(14px);
    pointer-events: auto;
  }

  .brand-link {
    display: inline-flex;
    text-decoration: none;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 2.2vw, 1.75rem);
    margin-left: auto;
  }

  .desktop-nav a {
    position: relative;
    padding-block: 0.7rem;
    font-size: 0.94rem;
    font-weight: 700;
    text-decoration: none;
  }

  .desktop-nav a::after {
    position: absolute;
    right: 0;
    bottom: 0.42rem;
    left: 0;
    height: 3px;
    border-radius: 2px;
    background: var(--magenta);
    content: '';
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 150ms ease-out;
  }

  .desktop-nav a:hover::after,
  .desktop-nav a:focus-visible::after {
    transform: scaleX(1);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .language-link {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border: 2.5px solid var(--ink);
    border-radius: 10px;
    background: var(--lavender);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
  }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 959px) {
    .desktop-nav,
    .header-cta,
    .header-actions > .language-link {
      display: none;
    }

    .header-actions {
      margin-left: auto;
    }

    .mobile-menu {
      position: relative;
      display: block;
    }

    .mobile-menu summary {
      display: flex;
      width: 2.9rem;
      height: 2.9rem;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      border: 2.5px solid var(--ink);
      border-radius: 10px;
      background: var(--acid);
      box-shadow: 3px 3px 0 var(--ink);
      list-style: none;
    }

    .mobile-menu summary::-webkit-details-marker {
      display: none;
    }

    .mobile-menu summary span {
      width: 1.25rem;
      height: 2.5px;
      border-radius: 2px;
      background: var(--ink);
      transition: transform 150ms ease-out, opacity 150ms ease-out;
    }

    .mobile-menu[open] summary span:nth-child(1) {
      transform: translateY(6.5px) rotate(45deg);
    }

    .mobile-menu[open] summary span:nth-child(2) {
      opacity: 0;
    }

    .mobile-menu[open] summary span:nth-child(3) {
      transform: translateY(-6.5px) rotate(-45deg);
    }

    .mobile-menu nav {
      position: absolute;
      top: calc(100% + 0.7rem);
      right: 0;
      display: grid;
      width: min(19rem, calc(100vw - 2rem));
      gap: 0.35rem;
      padding: 0.75rem;
      border: var(--line);
      border-radius: 14px;
      background: var(--surface);
      box-shadow: 7px 7px 0 var(--ink);
    }

    .mobile-menu nav > a:not(.button) {
      min-height: 2.9rem;
      padding: 0.7rem 0.8rem;
      border-radius: 8px;
      font-weight: 700;
      text-decoration: none;
    }

    .mobile-menu nav > a:not(.button):hover {
      background: var(--lavender);
    }
  }

  @media (max-width: 599px) {
    .site-header {
      padding: 0.45rem 0.6rem;
    }

    .header-shell {
      min-height: 3.75rem;
      padding: 0.35rem 0.4rem 0.35rem 0.65rem;
      border-radius: 14px;
      box-shadow: 3px 3px 0 var(--ink);
    }
  }
</style>
