# Public build-time configuration. Values are embedded into the static build.
PUBLIC_SITE_URL=https://jibiki.app
PUBLIC_APP_URL=https://my.jibiki.app
# Leave empty until the public API origin is ready. The landing demo remains useful without it.
PUBLIC_API_URL=
# Empty means no Google script, cookie, consent banner, or analytics request.
PUBLIC_GA_MEASUREMENT_ID=
# Optional Search Console verification token, without the `google-site-verification=` prefix.
PUBLIC_GOOGLE_SITE_VERIFICATION=
