# jibiki public edge. The marketing site and Flutter application are built into
# the Caddy image, while Django media, static files and content packs stay on
# their shared volumes.

(security_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(self), geolocation=(), microphone=(), payment=()"
		-Server
	}
}

(privacy_safe_access_log) {
	log_append service "jibiki-edge"
	log_append release "{$JIBIKI_RELEASE}"
	log {
		output stdout
		format filter {
			request>headers>X-Session-Token delete
			resp_headers>Location delete
			request>remote_ip ip_mask 24 48
			request>client_ip ip_mask 24 48
			request>uri query {
				replace q REDACTED
				replace query REDACTED
				replace search REDACTED
				replace code REDACTED
				replace key REDACTED
				replace token REDACTED
			}
			wrap json
		}
	}
}

www.{$ROOT_DOMAIN} {
	import security_headers
	redir https://{$ROOT_DOMAIN}{uri} 308
}

{$ROOT_DOMAIN} {
	import security_headers
	import privacy_safe_access_log
	encode zstd gzip

	root * /srv/site
	@site_root path /
	redir @site_root /fr/ 308

	# The policy starts in report-only mode. Promote it only after production
	# reports confirm the exact Firebase, Sentry and GA endpoints in use.
	header Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; connect-src 'self' https://{$API_DOMAIN} https://www.google-analytics.com https://region1.google-analytics.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; manifest-src 'self'; worker-src 'self' blob:; report-uri https://{$API_DOMAIN}/api/v1/observability/csp-report"

	@versioned path /_astro/*
	header @versioned Cache-Control "public, max-age=31536000, immutable"
	@public_assets path /assets/* /brand/* /fonts/* /icons/* /og/*
	header @public_assets Cache-Control "public, max-age=3600, stale-while-revalidate=604800"
	@html path / /fr* /en* /404.html
	header @html Cache-Control "public, max-age=0, must-revalidate"

	try_files {path} {path}/ =404
	file_server

	handle_errors {
		@english_not_found {
			expression {http.error.status_code} == 404
			path /en/*
		}
		handle @english_not_found {
			rewrite * /en/404/index.html
			file_server
		}

		@localized_not_found expression {http.error.status_code} == 404
		handle @localized_not_found {
			rewrite * /fr/404/index.html
			file_server
		}
	}
}

{$APP_DOMAIN} {
	import security_headers
	import privacy_safe_access_log
	encode zstd gzip

	header X-Robots-Tag "noindex, nofollow, noarchive"
	header Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com; connect-src 'self' https: wss:; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; manifest-src 'self'; worker-src 'self' blob:; report-uri https://{$API_DOMAIN}/api/v1/observability/csp-report"

	root * /srv/app

	@source_maps path_regexp source_maps \.map$

	@bootstrap path / /index.html /flutter_bootstrap.js /flutter_service_worker.js /version.json
	header @bootstrap Cache-Control "no-store"
	@app_assets path /assets/* /canvaskit/* /icons/* /splash/*
	header @app_assets Cache-Control "public, max-age=3600, stale-while-revalidate=604800"
	@runtime path *.js *.wasm *.json
	header @runtime Cache-Control "public, max-age=0, must-revalidate"
	@spa_fallback {
		not file
	}
	header @spa_fallback Cache-Control "no-store"

	route {
		respond @source_maps 404
		try_files {path} /index.html
		file_server
	}
}

{$API_DOMAIN} {
	import security_headers
	import privacy_safe_access_log
	encode zstd gzip

	@csp_report path /api/v1/observability/csp-report
	handle @csp_report {
		request_body {
			max_size 32KB
		}
		reverse_proxy api:8000
	}

	@media path /media/*
	handle @media {
		uri strip_prefix /media
		root * /srv/media
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	@static path /static/*
	handle @static {
		uri strip_prefix /static
		root * /srv/static
		header Cache-Control "public, max-age=3600, stale-while-revalidate=604800"
		file_server
	}

	@packs path /packs/*
	handle @packs {
		uri strip_prefix /packs
		root * /srv/packs
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		reverse_proxy api:8000
	}
}
