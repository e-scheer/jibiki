# Copy to .env and adjust. Dev defaults work without any of these.

# ── Database (dev: compose exposes Postgres on localhost:5432) ────────────────
DATABASE_URL=postgres://jibiki:jibiki@localhost:5432/jibiki
POSTGRES_PASSWORD=jibiki

# ── Django (prod only; dev defaults work without these) ──────────────────────
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=api.jibiki.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.jibiki.app
SITE_DOMAIN=api.jibiki.app
# CORS for the Flutter *web* build in dev (native builds don't need it). Empty +
# DEBUG=1 allows all origins.
CORS_ALLOWED_ORIGINS=

# ── Auth (allauth headless) ──────────────────────────────────────────────────
# The app deep-link base allauth uses for email verification / password reset
# links and social callbacks. Use your registered scheme in prod.
HEADLESS_FRONTEND_BASE=jibiki://auth
# none | optional | mandatory. Dev leaves it "optional" so signup logs in at once.
ACCOUNT_EMAIL_VERIFICATION=mandatory

# Email / SMTP — leave EMAIL_HOST empty in dev (mail prints to the console). Set
# these in prod and the backend switches to SMTP automatically.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=jibiki <noreply@jibiki.app>

# Social login (allauth). Leave empty in dev. In prod set BOTH id + secret for a
# provider, or neither (settings guards against a half-wired Google provider).
SOCIALACCOUNT_GOOGLE_CLIENT_ID=
SOCIALACCOUNT_GOOGLE_CLIENT_SECRET=
# Apple: client_id (services id), key id, and the .p8 private key contents.
SOCIALACCOUNT_APPLE_CLIENT_ID=
SOCIALACCOUNT_APPLE_KEY_ID=
SOCIALACCOUNT_APPLE_PRIVATE_KEY=

# ── Community image storage → Cloudflare R2 (zero egress) — prod ─────────────
# Leave MEDIA_S3_BUCKET empty to keep mnemonic uploads on the local /media volume
# (served by Caddy). Set it to offload to Cloudflare R2 (or any S3-compatible
# store). R2 endpoint looks like https://<accountid>.r2.cloudflarestorage.com;
# point MEDIA_S3_CUSTOM_DOMAIN at your R2 public / CDN domain so URLs are clean.
MEDIA_S3_BUCKET=
MEDIA_S3_ENDPOINT_URL=
MEDIA_S3_REGION=auto
MEDIA_S3_ACCESS_KEY=
MEDIA_S3_SECRET_KEY=
MEDIA_S3_CUSTOM_DOMAIN=

# ── Community moderation tuning ──────────────────────────────────────────────
# Net upvotes a contributor needs before their mnemonics post straight to VISIBLE
# (below it, held as PENDING). Distinct reporters that auto-hide a mnemonic.
MNEMONIC_TRUST_THRESHOLD=10
MNEMONIC_AUTO_HIDE_REPORTS=3
